# Copy to backend/.env for local dev. Real values live in Render's env settings.
ENVIRONMENT=development

# Comma-separated allowed frontend origins (no trailing slash).
# Local Next.js dev server:
CORS_ORIGINS=http://localhost:3000

# Supabase Postgres connection string (unused by v1 /health; wired in with models).
DATABASE_URL=

# Admin auth (single admin; ADR-0005). Generate the hash with the bcrypt one-liner
# in backend/README.md. SECRET_KEY must be >= 32 bytes in production.
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SECRET_KEY=dev-insecure-change-me

# SSLCOMMERZ sandbox (ADR-0007). Store creds from the sandbox dashboard.
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_API_BASE=https://sandbox.sslcommerz.com
# Where the gateway returns the customer's browser after payment.
FRONTEND_URL=http://localhost:3000
