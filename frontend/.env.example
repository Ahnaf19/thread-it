# Copy to frontend/.env.local for local dev. In production, set this in Vercel's
# env settings (mark sensitive ones accordingly) — never commit real values.

# Base URL of the FastAPI backend. Local FastAPI dev server by default;
# in production this is the Render URL, e.g. https://thread-it-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
